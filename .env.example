# Database
# Для локальной разработки (без Docker)
APP_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/review_summarizer

# Для Docker Compose (используются переменные ниже)
# APP_DATABASE_URL будет автоматически сгенерирован из переменных ниже

# PostgreSQL настройки для Docker Compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=review_summarizer
POSTGRES_PORT=5432

# API settings
APP_API_HOST=0.0.0.0
APP_API_PORT=8000

# Streamlit settings
APP_STREAMLIT_PORT=8501

# Logging
APP_LOG_LEVEL=INFO

# OpenAI
APP_OPENAI_API_KEY=sk-key
APP_OPENAI_MODEL=gpt-4.1
APP_OPENAI_MODEL_MINI=gpt-4.1-mini
